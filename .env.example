# Copia este archivo a .env.local y rellena los valores.
# Next.js NO carga .env.example automáticamente.

# --- OpenAI (opcional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Autenticación Azure DevOps (elige uno: pat | oauth) ---
AZDO_AUTH_METHOD=pat

# --- OAuth Microsoft Entra + Azure DevOps (solo si AZDO_AUTH_METHOD=oauth) ---
AUTH_BASE_URL=http://localhost:3000
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Mínimo 32 caracteres (genera una aleatoria larga)
IRON_SESSION_PASSWORD=

# --- PAT (solo si AZDO_AUTH_METHOD=pat) ---
AZDO_ORGANIZATION=
AZDO_PROJECT=
# Equipo por defecto en el formulario (opcional). Debe coincidir con el nombre en Azure DevOps.
# Ejemplo: Plataforma Virtual - Studia LMS V2
AZDO_TEAM=
AZDO_PAT=
