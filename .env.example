# Copia este archivo a .env.local y rellena los valores.
# Next.js NO carga .env.example automáticamente.

# --- Base de datos (obligatorio para iniciar sesión) ---
# DATABASE_URL: pooled (app). DATABASE_URL_UNPOOLED: migraciones (npm run db:migrate).
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# ENCRYPTION_KEY: 32+ bytes en base64 (cifrado de PAT y tokens Microsoft en BD).
ENCRYPTION_KEY=

# --- Sesión (requerido) ---
# Mínimo 32 caracteres. También cachea perfil ADO (nombre/avatar) en cookie.
IRON_SESSION_PASSWORD=

# --- Autenticación Azure DevOps ---
# pat | oauth | both
AZDO_AUTH_METHOD=both

# OAuth Microsoft Entra (requerido si AZDO_AUTH_METHOD=oauth o both)
AUTH_BASE_URL=http://localhost:3000
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=common

# --- OpenAI (opcional; sin clave se usa interpretación heurística) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- SEO (opcional) ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_ALLOW_INDEXING=false

# --- Documentos legales /privacy y /terms (opcional; hay valores por defecto) ---
NEXT_PUBLIC_LEGAL_PUBLISHER=
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=

# --- Azure DevOps: ajustes de proceso (opcional; la app detecta valores por defecto) ---
AZDO_BACKLOG_ITEM_TYPE=Product Backlog Item
AZDO_TASK_WORK_ITEM_TYPE=Task
AZDO_BUG_WORK_ITEM_TYPE=Bug
AZDO_WORKING_DATE_FIELD=Custom.WorkingDate
AZDO_TIMEZONE=America/Bogota
AZDO_NON_WORKING_DATES=2025-01-01,2025-05-01
AZDO_PBI_FIELD_MAQUETACION=Custom.TuCampoMaquetacion
AZDO_PBI_FIELD_INTEGRADOR=Custom.TuCampoIntegrador
AZDO_PBI_FIELD_QA=Custom.TuCampoQA
AZDO_TASK_TODO_STATE=To Do
AZDO_TASK_DONE_STATE=Closed
