# Copia este archivo a .env.local y rellena los valores.
# Next.js NO carga .env.example automáticamente.

# --- SEO (opcional) ---
# URL pública de la app (Open Graph, sitemap, canonical). Si no se define, se usa AUTH_BASE_URL.
# Debe coincidir con la URL de producción y con AUTH_BASE_URL (p. ej. https://neosview.estremor.com).
# NEXT_PUBLIC_SITE_URL=https://neosview.estremor.com
# Por defecto la app no se indexa (datos de Azure DevOps). Pon "true" solo si quieres aparecer en buscadores.
# NEXT_PUBLIC_ALLOW_INDEXING=false

# --- Documentos legales (páginas /privacy y /terms para Microsoft Entra) ---
# NEXT_PUBLIC_LEGAL_PUBLISHER=Estremor
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=privacidad@estremor.com

# --- OpenAI (opcional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Autenticación Azure DevOps (pat | oauth | both) ---
# pat: PAT en variables de entorno (todos comparten la misma cuenta).
# oauth: cada usuario inicia sesión con Microsoft.
# both: el usuario elige Microsoft o código de acceso personal (requiere IRON_SESSION_PASSWORD).
AZDO_AUTH_METHOD=both

# --- OAuth Microsoft Entra + Azure DevOps (solo si AZDO_AUTH_METHOD=oauth) ---
AUTH_BASE_URL=http://localhost:3000
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Mínimo 32 caracteres (genera una aleatoria larga).
# También cachea el perfil ADO (nombre/avatar) en cookie para PAT y OAuth.
IRON_SESSION_PASSWORD=

# --- PAT (solo si AZDO_AUTH_METHOD=pat) ---
AZDO_ORGANIZATION=
AZDO_PROJECT=
# Equipo por defecto en el formulario (opcional). Debe coincidir con el nombre en Azure DevOps.
# Ejemplo: Plataforma Virtual - Studia LMS V2
AZDO_TEAM=
AZDO_PAT=

# Tipo de work item para historias en el formulario (Scrum: Product Backlog Item)
# AZDO_BACKLOG_ITEM_TYPE=Product Backlog Item

# Campos Responsable de la historia de usuario (Reference Name exacto en ADO). Opcional:
# si no se definen, la app intenta descubrirlos por el nombre visible del campo.
# AZDO_PBI_FIELD_MAQUETACION=Custom.TuCampoMaquetacion
# AZDO_PBI_FIELD_INTEGRADOR=Custom.TuCampoIntegrador
# AZDO_PBI_FIELD_QA=Custom.TuCampoQA

# Días no laborables extra (festivos), además de los del equipo en Azure DevOps.
# Formato: fechas YYYY-MM-DD separadas por coma.
# AZDO_NON_WORKING_DATES=2025-01-01,2025-05-01

# Campo principal de fecha de trabajo en Tasks (opcional; legacy hasta Settings).
# Solo se usa si existe en el proyecto ADO conectado; si no, se detecta "Working Date" o StartDate.
# En NARP: Custom.WorkingDate
# AZDO_WORKING_DATE_FIELD=Custom.WorkingDate

# Zona horaria del proyecto en Azure DevOps (IANA, ej. America/Bogota).
# Afecta la lectura de Working Date con hora y el agrupamiento del dashboard por día.
# AZDO_TIMEZONE=America/Bogota

# Tipo de work item para Tasks (opcional; por defecto Task)
# AZDO_TASK_WORK_ITEM_TYPE=Task

# Tipo de work item para Bugs (opcional; por defecto Bug)
# AZDO_BUG_WORK_ITEM_TYPE=Bug

# Estados por defecto si el proceso usa nombres personalizados (opcional)
# AZDO_TASK_DONE_STATE=Closed
# AZDO_TASK_TODO_STATE=To Do
